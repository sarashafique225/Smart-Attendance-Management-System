@{
    ViewData["Title"] = "Attendance Reports";
}

<h4 class="mb-4"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Attendance Reports</h4>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="fw-semibold">Department</label>
                <select id="deptDD" class="form-select" onchange="loadCourses()">
                    <option value="0">-- All Departments --</option>
                    @foreach (var d in ViewBag.Departments as List<SAMS.Models.Entities.Department>)
                    {
                        <option value="@d.DeptID">@d.DeptName</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="fw-semibold">Semester</label>
                <select id="semDD" class="form-select">
                    <option value="0">-- All --</option>
                    @for (int i = 1; i <= 8; i++)
                    {
                        <option value="@i">Semester @i</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="fw-semibold">Course / Subject</label>
                <select id="courseDD" class="form-select">
                    <option value="">-- Select Course --</option>
                    @foreach (var c in ViewBag.Courses as List<SAMS.Models.Entities.Course>)
                    {
                        <option value="@c.CourseID">@c.CourseName (@c.CourseCode)</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" onclick="loadReport()">
                    <i class="bi bi-search me-1"></i>Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

<div id="reportDiv" class="d-none">
    <div class="card shadow-sm">
        <div class="card-header fw-bold bg-primary text-white">
            <i class="bi bi-table me-2"></i>Attendance Report
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Reg No</th>
                        <th>Student Name</th>
                        <th>Present</th>
                        <th>Absent</th>
                        <th>Total</th>
                        <th>Percentage</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="reportBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadCourses() {
            const deptID = document.getElementById('deptDD').value;
            fetch('/Student/GetCourses?deptID=' + deptID)
                .then(r => r.json())
                .then(courses => {
                    const dd = document.getElementById('courseDD');
                    dd.innerHTML = '<option value="">-- Select Course --</option>';
                    courses.forEach(c => {
                        dd.innerHTML += `<option value="${c.courseID}">${c.courseName} (${c.courseCode})</option>`;
                    });
                });
        }

        function loadReport() {
            const cid = document.getElementById('courseDD').value;
            if (!cid) { alert('Please select a course!'); return; }

            fetch('/Report/GetReport?courseId=' + cid)
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('reportBody');
                    tbody.innerHTML = '';
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">No attendance data found for this course.</td></tr>';
                    } else {
                        let i = 1;
                        data.forEach(row => {
                            const pct = parseFloat(row.percentage) || 0;
                            const badge = pct >= 75
                                ? '<span class="badge bg-success">Good</span>'
                                : '<span class="badge bg-danger">Low</span>';
                            tbody.innerHTML += `<tr>
                                <td>${i++}</td>
                                <td><span class="badge bg-secondary">${row.regNo}</span></td>
                                <td>${row.fullName}</td>
                                <td>${row.totalPresent}</td>
                                <td>${row.totalAbsent}</td>
                                <td>${row.totalClasses}</td>
                                <td>
                                    ${pct}%
                                    <div class="progress mt-1" style="height:5px">
                                        <div class="progress-bar bg-${pct>=75?'success':'danger'}"
                                             style="width:${pct}%"></div>
                                    </div>
                                </td>
                                <td>${badge}</td>
                            </tr>`;
                        });
                    }
                    document.getElementById('reportDiv').classList.remove('d-none');
                });
        }
    </script>
}